{
  "name": "venture-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "quality": "pnpm lint && pnpm typecheck && pnpm build",
    "quality:full": "pnpm lint && pnpm typecheck && pnpm harness:check && pnpm release:check && pnpm build",
    "harness:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check_harness.ps1",
    "release:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check_release_readiness.ps1",
    "smoke:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke_production.ps1",
    "smoke:routes": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke_routes.ps1",
    "smoke:market": "node ./scripts/smoke_market_scan.mjs",
    "smoke:telemetry": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke_telemetry_ingest.ps1",
    "smoke:telemetry:funnel": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke_telemetry_ingest.ps1 -Funnel",
    "smoke:browser": "node ./scripts/smoke_browser.mjs",
    "smoke:browser:auth": "node ./scripts/smoke_browser_auth.mjs",
    "smoke:browser:rls": "node ./scripts/smoke_browser_rls.mjs",
    "smoke:browser:rls:preflight": "node ./scripts/smoke_browser_rls.mjs --preflight",
    "idea:score": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/score_idea.ps1"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
