NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. Never expose in browser bundles, screenshots, docs, artifacts, or relay packets.
SUPABASE_SERVICE_ROLE_KEY=
